import elementos.*
import plagas.*


describe "test de plagas" {
  const C1=new Cucaracha(poblacion=10, pesoPromedio=8)
  const H1=new Hogar(mugre=10,confort=21 )
  test "el hogar h1 es bueno si no recibe un ataque" {
    assert.that(H1.esBueno())
  }

  test"si hogar h1 recibe un ataque de c1, entonces ya no es bueno"{
  C1.atacar(H1)
  assert.notThat(H1.esBueno())
  }
}